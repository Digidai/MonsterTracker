{
  "name": "monstertracker",
  "version": "0.1.0",
  "description": "Cloudflare-native distributed website monitoring with Workers Placement Hints.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "scripts": {
    "dev": "wrangler dev --test-scheduled",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "db:migrate:local": "wrangler d1 migrations apply monstertracker --local",
    "db:migrate:remote": "wrangler d1 migrations apply monstertracker --remote",
    "generate:probes": "node scripts/generate-probe-configs.mjs",
    "list:placement-regions": "node scripts/list-supported-regions.mjs",
    "types": "wrangler types ./worker-configuration.d.ts",
    "check": "tsc --noEmit && vitest run",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  }
}
